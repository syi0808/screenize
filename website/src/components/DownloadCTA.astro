<section class="section" data-animate="reveal">
  <div class="container">
    <div class="cta-card">
      <div class="cta-glow"></div>
      <h2 class="cta-title">Ready to record?</h2>
      <p class="cta-subtitle">Download Screenize and start creating polished screen recordings in minutes.</p>
      <div class="cta-buttons">
        <a
          href="https://github.com/syi0808/screenize/releases/latest/download/Screenize.dmg"
          class="btn btn-primary"
          data-magnetic
          download
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download for macOS
        </a>
        <a
          href="https://github.com/syi0808/screenize"
          class="btn btn-ghost"
          data-magnetic
          target="_blank"
          rel="noopener noreferrer"
        >
          View on GitHub
        </a>
      </div>
      <p class="cta-note">Requires macOS 13.0 or later · Free and open source</p>
    </div>
  </div>
</section>

<style>
  .section {
    padding: 96px 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .cta-card {
    position: relative;
    padding: 64px;
    text-align: center;
    border-radius: var(--radius-lg);
    background: var(--bg-1);
    border: 1px solid var(--border-accent);
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    inset: -1px;
    border-radius: var(--radius-lg);
    background: radial-gradient(ellipse at 50% 0%, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .cta-title {
    position: relative;
    z-index: 1;
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-0);
    margin: 0;
  }

  .cta-subtitle {
    position: relative;
    z-index: 1;
    color: var(--text-1);
    max-width: 500px;
    margin: 16px auto 0;
    font-size: 18px;
    line-height: 1.6;
  }

  .cta-buttons {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 100px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    cursor: pointer;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent-start), var(--accent-end));
    color: #fff;
    box-shadow: 0 4px 24px rgba(99, 102, 241, 0.35);
  }

  .btn-primary:hover {
    box-shadow: 0 8px 32px rgba(99, 102, 241, 0.5);
  }

  .btn-ghost {
    background: transparent;
    color: var(--text-0);
    border: 1px solid var(--border-accent);
  }

  .btn-ghost:hover {
    background: rgba(99, 102, 241, 0.08);
    border-color: rgba(99, 102, 241, 0.5);
  }

  .cta-note {
    position: relative;
    z-index: 1;
    font-size: 13px;
    color: var(--text-2);
    margin-top: 16px;
  }

  @media (max-width: 768px) {
    .section {
      padding: 64px 0;
    }

    .cta-card {
      padding: 40px 24px;
    }

    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }

    .btn {
      width: 100%;
      justify-content: center;
      max-width: 320px;
    }
  }

  @media (max-width: 480px) {
    .section {
      padding: 48px 0;
    }

    .cta-card {
      padding: 32px 20px;
    }

    .cta-subtitle {
      font-size: 16px;
    }
  }
</style>
