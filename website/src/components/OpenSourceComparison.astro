---

<section id="open-source" class="open-source-comparison">
  <div class="container">

    <!-- Part 1: OSS value prop -->
    <div class="oss-value" data-animate="reveal">
      <h2 class="oss-title">Open source. Built by indie devs, for indie devs.</h2>
      <p class="oss-desc">
        Apache 2.0 licensed. No vendor lock-in, no hidden costs. Report bugs, submit PRs, or fork it and make it yours.
      </p>
      <p class="oss-author">
        Created by <a href="https://github.com/syi0808" class="author-link">Yein Sung</a>
      </p>
      <div class="oss-actions">
        <a href="https://github.com/syi0808/screenize" class="action-link" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          View Source
        </a>
        <a href="https://github.com/syi0808/screenize/issues" class="action-link" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          Report Issue
        </a>
        <a href="https://github.com/syi0808/screenize/blob/main/CONTRIBUTING.md" class="action-link" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          Contributing
        </a>
      </div>
    </div>

    <!-- Part 2: Comparison table -->
    <div class="comparison" data-animate="reveal">
      <h3 class="comparison-subtitle">Screenize vs Screen Studio</h3>
      <p class="comparison-desc">Both produce polished screen recordings with auto-zoom. Here's how they compare.</p>

      <div class="table-card">
        <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th class="col-feature">Feature</th>
              <th class="col-screenize">Screenize</th>
              <th class="col-competitor">Screen Studio</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Price</td>
              <td class="col-screenize"><strong>Free</strong></td>
              <td class="col-competitor">$89+</td>
            </tr>
            <tr>
              <td>Open source</td>
              <td class="col-screenize"><strong>Yes (Apache 2.0)</strong></td>
              <td class="col-competitor">No</td>
            </tr>
            <tr>
              <td>Auto-zoom</td>
              <td class="col-screenize"><strong>Continuous + Segment-based</strong></td>
              <td class="col-competitor">Automatic</td>
            </tr>
            <tr>
              <td>Timeline editor</td>
              <td class="col-screenize"><strong>Multi-track, fully editable keyframes</strong></td>
              <td class="col-competitor">Limited</td>
            </tr>
            <tr>
              <td>Click effects</td>
              <td class="col-screenize">Yes</td>
              <td class="col-competitor">Yes</td>
            </tr>
            <tr>
              <td>Keystroke overlays</td>
              <td class="col-screenize">Yes</td>
              <td class="col-competitor">Yes</td>
            </tr>
            <tr>
              <td>Custom cursors</td>
              <td class="col-screenize">7 styles</td>
              <td class="col-competitor">Yes</td>
            </tr>
            <tr>
              <td>Export formats</td>
              <td class="col-screenize">MP4, MOV (ProRes), GIF</td>
              <td class="col-competitor">MP4, MOV, GIF</td>
            </tr>
            <tr>
              <td>Max resolution</td>
              <td class="col-screenize">4K</td>
              <td class="col-competitor">4K</td>
            </tr>
            <tr>
              <td>Camera overlay</td>
              <td class="col-screenize">Planned</td>
              <td class="col-competitor">Yes</td>
            </tr>
          </tbody>
        </table>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .open-source-comparison {
    padding: 120px 0;
  }

  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  /* OSS value prop */
  .oss-value {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .oss-title {
    font-size: clamp(24px, 3.5vw, 36px);
    font-weight: 700;
    color: var(--text-0);
    margin-bottom: 16px;
  }

  .oss-desc {
    color: var(--text-1);
    font-size: 16px;
    line-height: 1.6;
    max-width: 560px;
    margin-bottom: 12px;
  }

  .oss-author {
    color: var(--text-2);
    font-size: 14px;
    margin-bottom: 32px;
  }

  .author-link {
    color: var(--text-1);
    text-decoration: none;
    transition: color 0.2s;
  }

  .author-link:hover {
    color: var(--text-0);
  }

  .oss-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .action-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius-md, 8px);
    color: var(--text-1);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    background: transparent;
  }

  .action-link:hover {
    color: var(--text-0);
    border-color: var(--text-2);
    background: var(--bg-1);
  }

  /* Comparison */
  .comparison {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .comparison-subtitle {
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 700;
    color: var(--text-0);
    margin-bottom: 4px;
  }

  .comparison-desc {
    color: var(--text-1);
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 8px;
  }

  .table-card {
    background: var(--bg-1);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
  }

  .table-scroll {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead tr {
    background: var(--bg-2);
  }

  th {
    text-align: left;
    padding: 16px 24px;
    font-size: 14px;
    color: var(--text-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  td {
    padding: 14px 24px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    color: var(--text-1);
    line-height: 1.4;
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  .col-feature {
    width: 30%;
  }

  .col-screenize {
    color: var(--text-0);
    width: 35%;
  }

  .col-competitor {
    color: var(--text-2);
    width: 35%;
  }

  td.col-screenize strong {
    color: var(--accent-start);
  }

  @media (max-width: 768px) {
    .container {
      gap: 56px;
    }
  }

  @media (max-width: 640px) {
    th,
    td {
      padding: 12px 16px;
      font-size: 13px;
    }

    .oss-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .action-link {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    table {
      min-width: 480px;
    }

    th,
    td {
      padding: 10px 12px;
      font-size: 12px;
    }
  }
</style>
